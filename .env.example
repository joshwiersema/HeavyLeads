# Database - Neon PostgreSQL
# Get your connection string from: Neon Console (https://console.neon.tech) -> Create Project -> Connection Details -> Connection string
DATABASE_URL=postgresql://user:pass@host/db

# Better Auth
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-random-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Google Maps (for geocoding HQ location during onboarding)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# After filling in values, copy this file:
# cp .env.example .env.local
# Then push the database schema:
# npx drizzle-kit push
