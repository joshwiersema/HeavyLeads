# ============================================================
# HeavyLeads Environment Variables
# ============================================================
# Copy this file and fill in your values:
#   cp .env.example .env.local
#
# Then push the database schema:
#   npm run db:push
# ============================================================

# --- Database (REQUIRED) ---
# Neon PostgreSQL connection string
# Get yours from: https://console.neon.tech -> Project -> Connection Details
DATABASE_URL=postgresql://user:pass@host/db

# --- Authentication (REQUIRED) ---
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-random-secret-here
# Your app's URL (use http://localhost:3000 for local dev)
BETTER_AUTH_URL=http://localhost:3000

# --- Stripe Billing (REQUIRED for billing features) ---
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from: Stripe Dashboard -> Webhooks -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from: Stripe Dashboard -> Products -> Prices
# Create a recurring monthly price for the subscription
STRIPE_MONTHLY_PRICE_ID=price_...
# Create a one-time price for the setup fee
STRIPE_SETUP_FEE_PRICE_ID=price_...

# --- Vercel Cron Security (REQUIRED for production) ---
# Secures the daily scraping cron job. Generate: openssl rand -base64 32
# Vercel auto-injects this as a Bearer token on cron requests.
# In local dev, cron routes won't run (Vercel Cron is production-only).
CRON_SECRET=generate-a-random-secret-here

# --- Google Maps (REQUIRED for geocoding) ---
# Get an API key from: https://console.cloud.google.com/apis/credentials
# Enable "Geocoding API" and "Maps JavaScript API"
GOOGLE_MAPS_API_KEY=your-server-side-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-client-side-google-maps-api-key

# --- Email via Resend (OPTIONAL - digest emails won't send without this) ---
# Get an API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Custom from address (requires domain verification in Resend)
RESEND_FROM_EMAIL=HeavyLeads <noreply@yourdomain.com>

# --- App URL (used in email links) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dev Access (OPTIONAL - demo/testing only) ---
# Set to "true" to show a "Skip" button on the billing page that grants
# full dashboard access without a Stripe subscription. Remove for production.
# NEXT_PUBLIC_DEV_ACCESS=true

# --- Scraper API Keys (OPTIONAL - adapters gracefully skip if missing) ---
# Google search results for lead discovery
SERPER_API_KEY=your-serper-api-key
# Government contract bids
SAM_GOV_API_KEY=your-sam-gov-api-key
